{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wbcom-essential/category-grid",
  "version": "1.0.0",
  "title": "Category Grid",
  "category": "starter-blog",
  "icon": "category",
  "description": "Display WordPress categories in a customizable grid layout with images, post counts, and hover effects.",
  "keywords": [
    "categories",
    "grid",
    "taxonomy",
    "blog",
    "magazine"
  ],
  "textdomain": "wbcom-essential",
  "example": {},
  "attributes": {
    "useThemeColors": {
      "type": "boolean",
      "default": false
    },
    "columns": {
      "type": "number",
      "default": 4
    },
    "columnsTablet": {
      "type": "number",
      "default": 2
    },
    "columnsMobile": {
      "type": "number",
      "default": 1
    },
    "selectedCategories": {
      "type": "array",
      "default": []
    },
    "excludeEmpty": {
      "type": "boolean",
      "default": true
    },
    "maxCategories": {
      "type": "number",
      "default": 8
    },
    "showPostCount": {
      "type": "boolean",
      "default": true
    },
    "showImage": {
      "type": "boolean",
      "default": true
    },
    "imageRatio": {
      "type": "string",
      "default": "0.75"
    },
    "gap": {
      "type": "number",
      "default": 24
    },
    "cardBorderRadius": {
      "type": "number",
      "default": 12
    },
    "cardBgColor": {
      "type": "string",
      "default": ""
    },
    "nameColor": {
      "type": "string",
      "default": ""
    },
    "countColor": {
      "type": "string",
      "default": ""
    },
    "overlayColor": {
      "type": "string",
      "default": ""
    },
    "orderBy": {
      "type": "string",
      "default": "name"
    },
    "order": {
      "type": "string",
      "default": "ASC"
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}